{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "Intentionally insecure RDS instances for VectorPlane remediation E2E testing",
  "Parameters": {
    "DBMasterUsername": {
      "Type": "String",
      "Default": "dbadmin",
      "Description": "Master username for RDS instances"
    },
    "DBMasterPassword": {
      "Type": "String",
      "NoEcho": true,
      "Default": "changeme123!",
      "Description": "Master password for RDS instances"
    }
  },
  "Resources": {
    "VPTestPaymentsDB": {
      "Type": "AWS::RDS::DBInstance",
      "Properties": {
        "DBInstanceClass": "db.t3.micro",
        "Engine": "mysql",
        "EngineVersion": "8.0.45",
        "MasterUsername": {
          "Ref": "DBMasterUsername"
        },
        "MasterUserPassword": {
          "Ref": "DBMasterPassword"
        },
        "AllocatedStorage": "20",
        "PubliclyAccessible": false,
        "MultiAZ": true,
        "DeletionProtection": false,
        "BackupRetentionPeriod": 7,
        "Tags": [
          {
            "Key": "Environment",
            "Value": "test"
          },
          {
            "Key": "ManagedBy",
            "Value": "vectorplane-e2e-test"
          }
        ],
        "EnableIAMDatabaseAuthentication": true,
        "AutoMinorVersionUpgrade": true,
        "CopyTagsToSnapshot": true,
        "MonitoringInterval": 60,
        "MonitoringRoleArn": {
          "Fn::GetAtt": [
            "VPTestMonitoringRole",
            "Arn"
          ]
        },
        "EnableCloudwatchLogsExports": [
          "general",
          "slowquery",
          "error",
          "audit"
        ]
      },
      "DeletionPolicy": "Delete"
    },
    "VPTestAnalyticsDB": {
      "Type": "AWS::RDS::DBInstance",
      "Properties": {
        "DBInstanceClass": "db.t3.micro",
        "Engine": "postgres",
        "EngineVersion": "14.22",
        "MasterUsername": "pgdbadmin",
        "MasterUserPassword": {
          "Ref": "DBMasterPassword"
        },
        "AllocatedStorage": "20",
        "PubliclyAccessible": false,
        "MultiAZ": true,
        "DeletionProtection": false,
        "BackupRetentionPeriod": 7,
        "Tags": [
          {
            "Key": "Environment",
            "Value": "test"
          },
          {
            "Key": "ManagedBy",
            "Value": "vectorplane-e2e-test"
          }
        ],
        "EnableIAMDatabaseAuthentication": true,
        "AutoMinorVersionUpgrade": true,
        "CopyTagsToSnapshot": true,
        "MonitoringInterval": 60,
        "MonitoringRoleArn": {
          "Fn::GetAtt": [
            "VPTestMonitoringRole",
            "Arn"
          ]
        },
        "EnableCloudwatchLogsExports": [
          "postgresql",
          "upgrade"
        ]
      },
      "DeletionPolicy": "Delete"
    },
    "VPTestMonitoringRole": {
      "Type": "AWS::IAM::Role",
      "Properties": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "monitoring.rds.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "ManagedPolicyArns": [
          "arn:aws:iam::aws:policy/service-role/AmazonRDSEnhancedMonitoringRole"
        ],
        "Tags": [
          {
            "Key": "ManagedBy",
            "Value": "vectorplane-e2e-test"
          }
        ]
      }
    }
  }
}
