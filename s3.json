{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "Intentionally insecure S3 buckets for VectorPlane remediation E2E testing",
  "Resources": {
    "VPTestDataBucket": {
      "Type": "AWS::S3::Bucket",
      "Properties": {
        "Tags": [
          {
            "Key": "Environment",
            "Value": "test"
          },
          {
            "Key": "ManagedBy",
            "Value": "vectorplane-e2e-test"
          }
        ],
        "LifecycleConfiguration": {
          "Rules": [
            {
              "Id": "cleanup",
              "Status": "Enabled",
              "ExpirationInDays": 90
            }
          ]
        }
      }
    },
    "VPTestLogsBucket": {
      "Type": "AWS::S3::Bucket",
      "Properties": {
        "Tags": [
          {
            "Key": "Environment",
            "Value": "test"
          },
          {
            "Key": "ManagedBy",
            "Value": "vectorplane-e2e-test"
          }
        ]
      }
    },
    "VPTestPublicBucket": {
      "Type": "AWS::S3::Bucket",
      "Properties": {
        "Tags": [
          {
            "Key": "Environment",
            "Value": "test"
          },
          {
            "Key": "ManagedBy",
            "Value": "vectorplane-e2e-test"
          }
        ]
      }
    }
  }
}
