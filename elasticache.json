{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "Intentionally insecure ElastiCache for VectorPlane remediation E2E testing",
  "Resources": {
    "VPTestRG": {
      "Type": "AWS::ElastiCache::ReplicationGroup",
      "Properties": {
        "ReplicationGroupDescription": "VP test replication group",
        "Engine": "redis",
        "CacheNodeType": "cache.t3.micro",
        "NumCacheClusters": 2,
        "AutomaticFailoverEnabled": true,
        "Tags": [
          {
            "Key": "Environment",
            "Value": "test"
          },
          {
            "Key": "ManagedBy",
            "Value": "vectorplane-e2e-test"
          }
        ],
        "SnapshotRetentionLimit": 7
      }
    }
  }
}