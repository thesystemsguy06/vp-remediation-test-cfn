{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "Intentionally insecure VPC and subnets for VectorPlane remediation E2E testing",
  "Resources": {
    "VPTestVPC": {
      "Type": "AWS::EC2::VPC",
      "Properties": {
        "CidrBlock": "10.0.0.0/16",
        "EnableDnsHostnames": true,
        "EnableDnsSupport": true,
        "Tags": [
          {
            "Key": "Environment",
            "Value": "test"
          },
          {
            "Key": "ManagedBy",
            "Value": "vectorplane-e2e-test"
          },
          {
            "Key": "Name",
            "Value": "vp-test-vpc"
          }
        ]
      }
    },
    "VPTestPublicSubnet": {
      "Type": "AWS::EC2::Subnet",
      "Properties": {
        "VpcId": {
          "Ref": "VPTestVPC"
        },
        "CidrBlock": "10.0.1.0/24",
        "AvailabilityZone": "us-east-1a",
        "MapPublicIpOnLaunch": true,
        "Tags": [
          {
            "Key": "Environment",
            "Value": "test"
          },
          {
            "Key": "ManagedBy",
            "Value": "vectorplane-e2e-test"
          },
          {
            "Key": "Name",
            "Value": "vp-test-public-subnet"
          }
        ]
      }
    },
    "VPTestPrivateSubnet": {
      "Type": "AWS::EC2::Subnet",
      "Properties": {
        "VpcId": {
          "Ref": "VPTestVPC"
        },
        "CidrBlock": "10.0.2.0/24",
        "AvailabilityZone": "us-east-1b",
        "MapPublicIpOnLaunch": false,
        "Tags": [
          {
            "Key": "Environment",
            "Value": "test"
          },
          {
            "Key": "ManagedBy",
            "Value": "vectorplane-e2e-test"
          },
          {
            "Key": "Name",
            "Value": "vp-test-private-subnet"
          }
        ]
      }
    },
    "VPTestInternetGateway": {
      "Type": "AWS::EC2::InternetGateway",
      "Properties": {
        "Tags": [
          {
            "Key": "Environment",
            "Value": "test"
          },
          {
            "Key": "ManagedBy",
            "Value": "vectorplane-e2e-test"
          }
        ]
      }
    },
    "VPTestVPCGatewayAttachment": {
      "Type": "AWS::EC2::VPCGatewayAttachment",
      "Properties": {
        "VpcId": {
          "Ref": "VPTestVPC"
        },
        "InternetGatewayId": {
          "Ref": "VPTestInternetGateway"
        }
      }
    },
    "VPTestVPCFlowLogGroup": {
      "Type": "AWS::Logs::LogGroup",
      "Properties": {
        "RetentionInDays": 30
      }
    },
    "VPTestVPCFlowLogRole": {
      "Type": "AWS::IAM::Role",
      "Properties": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Action": "sts:AssumeRole",
              "Effect": "Allow",
              "Principal": {
                "Service": "vpc-flow-logs.amazonaws.com"
              }
            }
          ]
        }
      }
    },
    "VPTestVPCFlowLogPolicy": {
      "Type": "AWS::IAM::Policy",
      "Properties": {
        "Roles": [
          {
            "Ref": "VPTestVPCFlowLogRole"
          }
        ],
        "PolicyName": "VPTestVPC-flowlogpolicy",
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Action": [
                "logs:CreateLogGroup",
                "logs:CreateLogStream",
                "logs:PutLogEvents",
                "logs:DescribeLogGroups",
                "logs:DescribeLogStreams"
              ],
              "Effect": "Allow",
              "Resource": "*"
            }
          ]
        }
      }
    },
    "VPTestVPCFlowLog": {
      "Type": "AWS::EC2::FlowLog",
      "Properties": {
        "ResourceId": {
          "Ref": "VPTestVPC"
        },
        "TrafficType": "REJECT",
        "LogGroupName": {
          "Ref": "VPTestVPCFlowLogGroup"
        },
        "ResourceType": "VPC",
        "DeliverLogsPermissionArn": {
          "Fn::GetAtt": [
            "VPTestVPCFlowLogRole",
            "Arn"
          ]
        }
      }
    }
  },
  "Outputs": {
    "VPCId": {
      "Description": "VPC ID",
      "Value": {
        "Ref": "VPTestVPC"
      },
      "Export": {
        "Name": "VPTestVPCId"
      }
    },
    "PublicSubnetId": {
      "Description": "Public Subnet ID",
      "Value": {
        "Ref": "VPTestPublicSubnet"
      },
      "Export": {
        "Name": "VPTestPublicSubnetId"
      }
    },
    "PrivateSubnetId": {
      "Description": "Private Subnet ID",
      "Value": {
        "Ref": "VPTestPrivateSubnet"
      },
      "Export": {
        "Name": "VPTestPrivateSubnetId"
      }
    }
  }
}
